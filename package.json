{
  "name": "agent-trees",
  "version": "0.1.0",
  "description": "Git worktrees for humans and agents",
  "type": "module",
  "bin": {
    "atree": "./dist/atree.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outfile dist/atree.js --banner '#!/usr/bin/env node' && chmod +x dist/atree.js",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/atree.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": ["git", "worktree", "cli", "developer-tools", "ai", "agents"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohit121/agent-trees.git"
  },
  "homepage": "https://github.com/rohit121/agent-trees",
  "bugs": {
    "url": "https://github.com/rohit121/agent-trees/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  }
}
